# Force embedding model onto GPU (optional). If unset, GPU is used when PyTorch reports CUDA.
# Set to "cpu" to force CPU. Requires PyTorch built with CUDA (e.g. pip install torch --index-url https://download.pytorch.org/whl/cu121).
# EMBEDDING_DEVICE=cuda

# LangSmith (optional): send traces to https://smith.langchain.com
# LANGSMITH_API_KEY=your-api-key
# LANGSMITH_TRACING=true
# Optional: project name (defaults: policy-assistant-ingest / policy-assistant-retrieval)
# LANGCHAIN_PROJECT=policy-assistant-ingest
# Optional: if your API key is linked to multiple workspaces
# LANGSMITH_WORKSPACE_ID=your-workspace-id
