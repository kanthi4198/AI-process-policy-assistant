# Force embedding model onto GPU (optional). If unset, GPU is used when PyTorch reports CUDA.
# Set to "cpu" to force CPU. Requires PyTorch built with CUDA (e.g. pip install torch --index-url https://download.pytorch.org/whl/cu121).
# EMBEDDING_DEVICE=cuda

# LangSmith (optional): set one of these to send traces to smith.langchain.com
# LANGSMITH_API_KEY=your-api-key
# LANGCHAIN_API_KEY=your-api-key

# Optional: LangSmith project name (defaults to policy-assistant-retrieval / policy-assistant-ingest)
# LANGCHAIN_PROJECT=policy-assistant-retrieval
